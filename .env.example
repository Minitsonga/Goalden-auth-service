NODE_ENV=development
PORT=3001

# Base MongoDB du service auth (ex. Atlas)
MONGO_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/goalden_auth?retryWrites=true&w=majority

# JWT des utilisateurs (meme valeur sur gateway, event, team, social, file)
USER_JWT_SECRET=
USER_JWT_EXPIRES_IN=1h
REFRESH_TOKEN_EXPIRES_IN=7d

# JWT inter-services (meme valeur sur services qui emettent ou verifient des tokens service)
SERVICE_JWT_SECRET=

# Credentials M2M pour POST /internal/service-token (uniquement les services qui demandent un token)
# serviceId = AUTH_SERVICE_CLIENT_ID du consommateur ; secret = AUTH_SERVICE_CLIENT_SECRET du meme service
# Ne pas lister team / notification / file / gateway tant qu'ils n'appellent pas cet endpoint
# Format: serviceId:secret,serviceId:secret
SERVICE_SECRETS=event-service:CHANGE_ME,social-service:CHANGE_ME
